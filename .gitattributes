# Treat all binary asset formats as binary to prevent line-ending
# conversion from corrupting them on Windows checkouts.
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.mp3 binary
*.wav binary
*.ogg binary
*.mp4 binary
*.zip binary
*.gz binary
*.tgz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
