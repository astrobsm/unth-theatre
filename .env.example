# Database Configuration (Supabase PostgreSQL)
# DATABASE_URL uses the Supabase connection pooler (port 6543, transaction mode)
# DIRECT_URL uses direct connection (port 5432) for Prisma migrations
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres"

# NextAuth Configuration
# For local: http://localhost:3000
# For production: https://your-app-name.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# NextAuth Secret - Generate a random secret for production
# Run: openssl rand -base64 32
# Or use: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"

# ============================================================
# Azure Speech (Neural TTS) — used by /api/training/tts
# Required ONLY if you want natural human voiceovers (Ezinne/Abeo Nigerian, Aria, Sonia, Jenny, Guy).
# Without these, the downloads page falls back to free offline meSpeak.
# How to obtain (5 minutes, free F0 tier = 0.5 M chars/month):
#   1. Sign in at https://portal.azure.com
#   2. "Create a resource" → search "Speech" → publisher Microsoft → Create
#   3. Subscription = your subscription, Resource group = orm-rg (create new),
#      Region = "northeurope" (closest to Nigeria), Name = unth-orm-speech,
#      Pricing tier = "Free F0"
#   4. After deployment → "Go to resource" → left menu "Keys and Endpoint"
#   5. Copy KEY 1  →  AZURE_SPEECH_KEY
#   6. Copy Location/Region (e.g. "northeurope") → AZURE_SPEECH_REGION
# ============================================================
AZURE_SPEECH_KEY=""
AZURE_SPEECH_REGION="northeurope"
AZURE_SPEECH_DEFAULT_VOICE="en-NG-EzinneNeural"

# ============================================================
# ElevenLabs (Natural TTS) — used by /api/radio/tts
# Voices EVERY Theatre Radio announcement and emergency surgery alert.
# If ELEVENLABS_API_KEY is unset, the players fall back to the free offline
# browser voice (window.speechSynthesis) automatically.
# How to obtain: sign in at https://elevenlabs.io → Profile → API Keys → copy.
#   ELEVENLABS_VOICE_ID is the voiceId in the voice-library URL; defaults to the
#   shared voice WjrbdoJBxxaidWT9VRDg when left blank.
# Add these to Vercel → Project → Settings → Environment Variables for production.
# ============================================================
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID="WjrbdoJBxxaidWT9VRDg"
ELEVENLABS_MODEL_ID="eleven_multilingual_v2"
# Delivery tuning, all 0..1 (blank = the defaults below, which are set for a
# human read). Lower stability = more natural variation, higher = flatter and
# more machine-like; style adds emphasis. Bad values are ignored.
ELEVENLABS_STABILITY="0.4"
ELEVENLABS_SIMILARITY="0.8"
ELEVENLABS_STYLE="0.3"
